[Unit]
Description=pypi-tea - TEA Server for PyPI Package SBOMs
After=network.target redis.service
Wants=redis.service

[Service]
Type=exec
User=nobody
Group=nogroup

# App configuration
Environment=PYPI_TEA_REDIS_URL=redis://localhost:6379/0
Environment=PYPI_TEA_SERVER_ROOT_URL=http://localhost:8000

# uvx needs a writable cache dir
Environment=XDG_CACHE_HOME=/tmp/pypi-tea-cache

ExecStart=/usr/local/bin/uvx --from pypi-tea uvicorn pypi_tea.app:app --host 127.0.0.1 --port 8000

Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/tmp/pypi-tea-cache

[Install]
WantedBy=multi-user.target
